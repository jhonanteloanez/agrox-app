  centroid_lon      Decimal?                 @db.Decimal(9, 6)
  area_m2           Decimal?                 @db.Decimal(14, 2)
  elevation_m       Decimal?                 @db.Decimal(7, 2)
  address           String?                  @db.VarChar(180)
  climate_radius_km Decimal?                 @db.Decimal(5, 2)
  status            status_basic?
  created_at        DateTime?                @db.Timestamptz(6)
  updated_at        DateTime?                @db.Timestamptz(6)
  deleted_at        DateTime?                @db.Timestamptz(6)

  @@ignore
  @@schema("public")
}

model seat_assignment {
  seat_id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id String       @db.Uuid
  user_id         String?      @db.Uuid
  status          seat_status  @default(FREE)
  held_until      DateTime?    @db.Timestamptz(6)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @default(now()) @db.Timestamptz(6)
  subscription    subscription @relation(fields: [subscription_id], references: [subscription_id], onDelete: Cascade, onUpdate: NoAction)
  users           users?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "seat_assignment_user_id_fkey1")

  @@unique([subscription_id, user_id], map: "uk_seat_per_user")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)

  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subscription {
  subscription_id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id        String              @db.Uuid
  plan_code              String              @db.VarChar(10)
  seat_limit             Int
  billing_mode           billing_mode        @default(MANUAL)
  status                 subscription_status @default(ACTIVE)
  start_date             DateTime            @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date               DateTime?           @db.Date
  next_billing           DateTime?           @db.Date
  billing_adjust_pending Boolean             @default(false)
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @default(now()) @db.Timestamptz(6)
  payment                payment[]
  seat_assignment        seat_assignment[]
  organization           organization        @relation(fields: [organization_id], references: [organization_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organization_id, status])
  @@schema("public")
}

model user_auth {
  user_id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  hashed_password String
  failed_attempts Int?      @default(0)
  account_locked  Boolean?  @default(false)
  lock_until      DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model user_consent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  consent_type String
  accepted     Boolean
  version      String
  ip_address   String?
  accepted_at  DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model user_roles {
  role_id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String?       @db.Uuid
  organization_id String?       @db.Uuid
  role            String
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?     @default(now()) @db.Timestamptz(6)
  organization    organization? @relation(fields: [organization_id], references: [organization_id], onDelete: NoAction, onUpdate: NoAction)
  users           users?        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, organization_id], map: "user_roles_unique")
  @@schema("public")
}

